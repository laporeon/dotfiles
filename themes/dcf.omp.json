// 20230919124057
// https://gist.githubusercontent.com/laporeon/0bd7ef9a929e52fca9e1b03de7cd3b59/raw/f49f775d6517e68cc4d4dbcf3254f256445a57d0/dcf.omp.json

{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#69c8ff",
          "properties": {
            "style": "folder"
          },
          "style": "plain",
          "template": "{{ .Path }}",
          "type": "path"
        },
        {
          "foreground": "#FFF",
          "properties": {
            "branch_icon": " "
          },
          "style": "plain",
          "template": " <#ffffff>on</> <#ff6600>{{ .HEAD }}</>",
          "type": "git"
        },
        {
          "foreground": "#c2d94c",
          "style": "plain",
          "template": " ✗",
          "type": "exit"
        },
        {
          "foreground": "#ffffff",
          "properties": {
            "style": "austin",
            "threshold": 0
          },
          "style": "diamond",
          "template": "<#ffffff> took</> <#c2d94c>{{ .FormattedMs }}</>",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#00c200",
          "style": "plain",
          "template": "❯",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 2
}
