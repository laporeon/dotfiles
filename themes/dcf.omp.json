{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#69c8ff",
          "properties": {
            "style": "folder"
          },
          "style": "plain",
          "template": "<#00c200>⬢</>  {{ .Path }}",
          "type": "path"
        },
        {
          "foreground": "#FFF",
          "properties": {
            "branch_icon": " "
          },
          "style": "plain",
          "template": "<#ff6600> {{ .HEAD }} </>",
          "type": "git"
        },
        {
          "foreground": "#c2d94c",
          "style": "plain",
          "template": " \u2717",
          "type": "exit"
        },
        {
          "foreground": "#00c200",
          "style": "plain",
          "template": "\u276f",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 2
}
